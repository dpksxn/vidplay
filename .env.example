# --- Supabase ---
# Create a project at https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Replicate (image-to-video model) ---
# Get a token at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# Public app URL (used for Replicate webhook). Use ngrok URL in dev.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Shared secret used to verify Replicate webhook calls.
# Generate with: openssl rand -hex 32
REPLICATE_WEBHOOK_SECRET=
